{
  "manifest_version": 3,
  "name": "Aula Session Sync",
  "version": "1.0",
  "description": "Automatically syncs Aula session cookies to your dashboard",
  "permissions": [
    "cookies",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://www.aula.dk/*",
    "https://aulanybo.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.aula.dk/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Aula Session Sync",
    "default_popup": "popup.html"
  }
}
